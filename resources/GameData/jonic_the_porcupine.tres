script = ExtResource("1_qb7f6")
title = "Jonic The Porcupine"
description = "Jonic the Porcupine, a blue porcupine with supersonic speed, must navigate the terrain and dodge hazards to foil the plans of Dr. Roumbanik, a mad scientist who imprisoned animals to turn them into robots and is trying to find the Chaos Stones."
