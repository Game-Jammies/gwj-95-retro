script = ExtResource("1_4ubsl")
title = "Super Guinny Kart"
description = "Super Guinny Kart is a kart racing game that features eight iconic characters from the Super Guinny series competing in fast paced races. Players can race in four cups, take time trials, or battle against each other by using different powers ups available in the game."
