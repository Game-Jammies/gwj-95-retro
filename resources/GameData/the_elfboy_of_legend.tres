script = ExtResource("1_g03ae")
title = "The Elfboy of Legend"
description = "Follow the story of young Elfboy, who must rescue a princess from the evil and demonic King Ganon. The evil King has put a spell on his lair which can only be removed with the threee pieces of the Quadforce, a golden rectangle with mystical powers."
genre = Array[int]([0, 2])
