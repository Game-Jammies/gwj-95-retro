[resource]
script = ExtResource("1_ytnqj")
title = "Guinny's Adventure"
description = "After Queen Tetete breaks the Moon Rod, the power source for the Fountain of Veggies, Guinny must travel across Dream Land to gather it's pieces from Tetete's minions. This is the second game in the Guinny franchise, but it is known for being the first game in the series to introduce Guinny's ability to copy abilities."
